---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';

const steps = [
  {
    icon: 'map-pin',
    title: '地域のハザードを知る',
    desc: 'ハザードマップや自治体の情報から、自社周辺の地震・水害・土砂リスクを確認する。',
    href: '/prepare/hazard',
  },
  {
    icon: 'shield',
    title: '安全を確保する',
    desc: '従業員の安全確保、避難経路の整備、安否確認手段の準備。命を守ることが最優先。',
    href: '/prepare/safety',
  },
  {
    icon: 'home',
    title: '被害を減らす',
    desc: '耐震補強・設備固定、止水板・電気設備のかさ上げなど、地震・水害による被害の軽減策。',
    href: '/prepare/damage',
  },
  {
    icon: 'document',
    title: '対策を計画する',
    desc: '事業継続計画の策定、優先業務の洗い出し、復旧目標の設定。事業継続力強化計画の認定で補助金加点や融資優遇も。',
    href: '/prepare/bcp',
  },
  {
    icon: 'box',
    title: '生活を守る',
    desc: '従業員用の水・食料・衛生用品の備蓄、データのバックアップ、代替調達先の確保。',
    href: '/prepare/life',
  },
  {
    icon: 'users',
    title: '訓練をする',
    desc: '避難訓練、安否確認の実施、BCP発動シミュレーション。定期的な見直し。',
    href: '/prepare/training',
  },
  {
    icon: 'banknote',
    title: '資金・保険を備える',
    desc: '損害保険・共済の点検、手元資金の確保、災害時の融資制度を事前に知る。',
    href: '/prepare/fund',
  },
  {
    icon: 'book-open',
    title: '更に知りたい人へ',
    desc: 'BCP・防災に関するガイドライン、自治体の支援窓口、参考になる外部リンク集。',
    href: '/prepare/links',
  },
];
---
<Base title="平時の備え｜ReadyBridge">
  <section class="hero" style="padding-bottom:18px">
    <div class="container hero-center">
      <span class="eyebrow reveal"><span class="dot"></span>平時の備え ／ これから備える企業へ</span>
      <h1 class="reveal d1" style="font-size:clamp(1.8rem,4vw,2.8rem)">事業を止めないための、<span class="accent">平時の備え。</span></h1>
      <p class="lead reveal d2">「何から始めればいいかわからない」を解消する。リスクの把握から資金の備えまで、いまできることを整理しました。</p>
    </div>
  </section>

  <section style="padding-top:8px">
    <div class="container">
      <div class="section-head"><span class="kicker">ACTIONS</span><h2>いまできる備え</h2><p>それぞれのテーマごとに、具体的な対策と公的支援をまとめています。</p></div>
      <div class="prep-grid">
        {steps.map((s) => (
          <a class="prep-card" href={s.href}>
            <span class="prep-icon"><Icon name={s.icon} size={30} /></span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
            <span class="prep-btn">詳しく見る<span class="arr">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .prep-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 18px;
  }
  .prep-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 30px 22px 26px;
    text-decoration: none;
    color: var(--ink);
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
  }
  .prep-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: var(--line-strong);
  }
  .prep-icon {
    display: grid;
    place-items: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--teal-soft);
    color: var(--teal);
    margin-bottom: 16px;
  }
  .prep-card h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    margin: 0 0 8px;
  }
  .prep-card p {
    font-size: 0.9rem;
    color: var(--muted);
    margin: 0 0 20px;
    flex: 1;
  }
  .prep-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--teal);
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 10px 22px;
    border-radius: 999px;
    transition: background 0.15s;
  }
  .prep-btn .arr { transition: transform 0.2s; }
  .prep-card:hover .prep-btn { background: var(--teal-dark); }
  .prep-card:hover .prep-btn .arr { transform: translateX(4px); }
</style>
