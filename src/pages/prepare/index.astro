---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';

const steps = [
  {
    icon: 'map-pin',
    title: '地域のハザードを知る',
    desc: 'ハザードマップや自治体の情報から、自社周辺の地震・水害・土砂リスクを確認する。',
    href: '/prepare/hazard',
  },
  {
    icon: 'shield',
    title: '安全を確保する',
    desc: '従業員の安全確保、避難経路の整備、安否確認手段の準備。命を守ることが最優先。',
    href: '/prepare/safety',
  },
  {
    icon: 'home',
    title: '被害を減らす',
    desc: '耐震補強・設備固定、止水板・電気設備のかさ上げなど、地震・水害による被害の軽減策。',
    href: '/prepare/damage',
  },
  {
    icon: 'box',
    title: '生活を守る',
    desc: '従業員用の水・食料・衛生用品の備蓄、データのバックアップ、代替調達先の確保。',
    href: '/prepare/life',
  },
  {
    icon: 'document',
    title: '対策を計画する',
    desc: '事業継続計画の策定、優先業務の洗い出し、復旧目標の設定。事業継続力強化計画の認定で補助金加点や融資優遇も。',
    href: '/prepare/bcp',
  },
  {
    icon: 'users',
    title: '訓練をする',
    desc: '避難訓練、安否確認の実施、BCP発動シミュレーション。定期的な見直し。',
    href: '/prepare/training',
  },
  {
    icon: 'banknote',
    title: '資金・保険を備える',
    desc: '損害保険・共済の点検、手元資金の確保、災害時の融資制度を事前に知る。',
    href: '/prepare/fund',
  },
  {
    icon: 'book-open',
    title: '更に知りたい人へ',
    desc: 'BCP・防災に関するガイドライン、自治体の支援窓口、参考になる外部リンク集。',
    href: '/prepare/links',
  },
];
---
<Base title="平時の備え｜ReadyBridge">
  <section class="hero" style="padding-bottom:18px">
    <div class="container">
      <span class="eyebrow reveal"><span class="dot"></span>平時の備え ／ これから備える企業へ</span>
      <h1 class="reveal d1 hero-head-line" style="font-size:clamp(1.8rem,4vw,2.8rem)">事業を止めないための、<span class="accent">平時の備え。</span></h1>
      <p class="lead lead-nowrap reveal d2">「何から始めればいいかわからない」を解消する。リスクの把握から資金の備えまで、いまできることを整理しました。</p>
    </div>
  </section>

  <section style="padding-top:8px">
    <div class="container">
      <div class="section-head"><span class="kicker">ACTIONS</span><h2>いまできる備え</h2><p>それぞれのテーマごとに、具体的な対策と公的支援をまとめています。</p></div>
      <div class="prep-grid">
        {steps.map((s, i) => (
          <a class="prep-card" href={s.href}>
            <span class="prep-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="prep-icon"><Icon name={s.icon} size={30} /></span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
            <span class="prep-btn">詳しく見る<span class="arr">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
