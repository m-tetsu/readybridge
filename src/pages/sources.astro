---
import Base from '../layouts/Base.astro';

const sources = [
  { label: '中小企業庁（災害対策）', url: 'https://www.chusho.meti.go.jp/' },
  { label: '中小機構 J-Net21 支援情報ヘッドライン', url: 'https://j-net21.smrj.go.jp/' },
  { label: 'ミラサポplus', url: 'https://mirasapo-plus.go.jp/' },
  { label: '内閣府 防災情報', url: 'https://www.bousai.go.jp/' },
  { label: '経済産業省', url: 'https://www.meti.go.jp/' },
  { label: '厚生労働省', url: 'https://www.mhlw.go.jp/' },
  { label: '国税庁', url: 'https://www.nta.go.jp/' },
  { label: '日本政策金融公庫', url: 'https://www.jfc.go.jp/' },
];
---
<Base title="情報源｜ReadyBridge">
  <section class="hero">
    <div class="container">
      <span class="eyebrow reveal"><span class="dot"></span>情報源</span>
      <h1 class="reveal d1" style="font-size:clamp(1.8rem,4vw,2.8rem)">参照する<span class="accent">政府・公的機関</span></h1>
      <p class="lead reveal d2">本サイトが参照する主なソースです。今後、これらを定期巡回して最新の支援情報を反映する予定です。</p>
    </div>
  </section>
  <section style="padding-top:10px">
    <div class="container" style="max-width:780px">
      <article class="article">
        <ul class="linklist">
          {sources.map((s) => (
            <li><a href={s.url} target="_blank" rel="noopener"><span>{s.label}</span><span style="color:var(--terra)">↗</span></a></li>
          ))}
        </ul>
        <p class="disclaimer">今後は、これらのソースを定期巡回して新着・変更を検知し、各情報の最終更新日を表示する仕組みを整備する予定です。</p>
      </article>
    </div>
  </section>
</Base>
