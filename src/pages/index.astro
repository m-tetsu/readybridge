---
import Base from '../layouts/Base.astro';
import SearchBox from '../components/SearchBox.astro';
import { PILLARS, categoriesByPillar, CATEGORIES, type PillarKey } from '../categories';

const pillarKeys = Object.keys(PILLARS) as PillarKey[];

const trust = [
  { h: '平時の備えも、有事の対応も', p: 'BCP・備蓄などの「備え」と、被災後の支援の「活用」を、ひとつの場所で。' },
  { h: '状況から、最短で必要な情報へ', p: 'お困りごと・キーワード検索で、いま必要な情報にすぐたどり着けます。' },
  { h: '中小企業の目線で、やさしく整理', p: '専門用語をかみくだき、次にとるべき一手を具体的にお伝えします。' },
];

const pillarIcons: Record<string, string> = {
  prepare:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5.5c0 4.2-2.9 7.6-7 8.9-4.1-1.3-7-4.7-7-8.9V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg>',
  recover:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M15.2 6.6a3.8 3.8 0 0 0-5 4.9L4.5 17.2a1.6 1.6 0 0 0 2.3 2.3l5.7-5.7a3.8 3.8 0 0 0 4.9-5l-2.4 2.4-2-2 2.2-2.6z"/></svg>',
};
---
<Base title="ReadyBridge｜事業継続を、平時から有事まで">
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-figure reveal">
        <div class="hero-overlay">
          <span class="eyebrow"><span class="dot"></span>中小企業の事業継続（BCP）を、平時から有事まで</span>
          <h1>備えるときも、<span class="accent">続けるときも。</span></h1>
        </div>
        <img class="hero-img" src="/hero.webp" alt="左：平時にBCPや備蓄で備える企業。右：被災後に復旧作業・支援物資の搬入・炊き出しで地域を支える企業。" width="1654" height="951" loading="eager" />
      </div>

      <div class="hero-center reveal d3" id="search">
        <p class="lead lead-nowrap">平時の備えから、被災後の再建まで。事業を止めないために、企業が確認すべき公的支援と備えを、まとめて探せます。</p>
        <div style="margin-top:18px">
          <SearchBox />
        </div>
      </div>
    </div>
  </section>

  <!-- 2大選択：平時／有事 -->
  <section style="padding-top:14px">
    <div class="container">
      <div class="section-head">
        <span class="kicker-lg">Start here</span>
        <h2>あなたの状況から選ぶ</h2>
        <p>「これから備えたい」のか「いま被災して困っている」のか。状況に合わせて選んでください。</p>
      </div>
      <div class="pillars">
        {pillarKeys.map((key) => {
          const p = PILLARS[key];
          const cats = categoriesByPillar(key);
          return (
            <a class={`pillar-card ${key}`} href={p.href}>
              <span class="pc-icon" set:html={pillarIcons[key]} />
              <span class="pc-tag">{p.tagline}</span>
              <h3>{p.label}</h3>
              <p class="pc-desc">{p.desc}</p>
              <div class="pc-cats">
                {cats.map((c) => <span>{CATEGORIES[c].label}</span>)}
              </div>
              <span class="pc-go">{p.label}を見る →</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 信頼バンド -->
  <section>
    <div class="container">
      <div class="trust">
        <h2>「馴染みのない備え・支援」を、迷わず使えるように。</h2>
        <p>ReadyBridge は、企業と支援制度、企業と社会、そして平時と有事をつなぎます。要点と根拠を整理してお届けします。</p>
        <div class="trust-grid">
          {trust.map((t) => (
            <div class="item">
              <span class="bar"></span>
              <p class="h">{t.h}</p>
              <p>{t.p}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- AI相談CTA -->
  <section style="padding-top:0">
    <div class="container">
      <div class="section-head">
        <span class="kicker">AI</span>
        <h2>見つからないときは、AIに相談</h2>
        <p>自社の状況に合わせた個別の質問や、災害ごとに変わる最新の支援について、出典付きで回答します。気になることを、そのまま聞いてみてください。</p>
      </div>
      <p><a class="btn" href="/chat">AIに相談する<span class="arr">→</span></a></p>
    </div>
  </section>
</Base>
